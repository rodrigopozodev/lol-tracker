# Plantilla: NO pongas aquí tu clave real. Copia este archivo:
#   cp .env.example .env.local
# y edita .env.local (Next.js solo carga .env*, .env.local, etc.; NUNCA lee .env.example).

RIOT_API_KEY=RGAPI-reemplaza-por-tu-clave

# Opcional: Tracker Network (tracker.gg) para búsqueda por prefijo tipo tracker.gg en el buscador.
# Crea una app en https://tracker.gg/developers — el acceso a LoL puede requerir permisos/whitelist.
# Si en consola del servidor ves [trn] lol search HTTP 401, la clave no la acepta public-api.tracker.gg:
#   regenera la API Key en el dashboard, pégala sin comillas, y reinicia "pnpm dev".
# TRN_API_KEY=tu-uuid-de-tracker
#
# Si la clave TRN no funciona y quieres omitir esas llamadas (más rápido; solo búsqueda ampliada Riot):
# TRN_SKIP_LOL_SEARCH=1

# Opcional: zona horaria para fechas en la UI (por defecto Europe/Madrid)
# NEXT_PUBLIC_HOME_DISPLAY_TZ=Europe/Madrid

# Opcional: id de la unidad AdSense cuando exista
# NEXT_PUBLIC_ADSENSE_SLOT=1234567890
